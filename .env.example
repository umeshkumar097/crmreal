# =============================================================================
# AI Real Estate CRM — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_NAME="AI Real Estate CRM"
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── DATABASE (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL="postgresql://crm_user:crm_password@localhost:5432/crm_db?schema=public"
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=crm_db
DATABASE_USER=crm_user
DATABASE_PASSWORD=crm_password

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CLOUDFLARE R2 (Primary Storage) ─────────────────────────────────────────
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=crm-storage
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# ─── AWS S3 (Fallback Storage) ───────────────────────────────────────────────
# STORAGE_PROVIDER=s3
# S3_REGION=ap-south-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=crm-storage
# S3_PUBLIC_URL=https://crm-storage.s3.ap-south-1.amazonaws.com

# ─── AZURE BLOB (Fallback Storage) ───────────────────────────────────────────
# STORAGE_PROVIDER=azure
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=crm-storage

# ─── AI PROVIDERS ────────────────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini (Secondary)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# ─── WHATSAPP (Meta Cloud API - Primary) ─────────────────────────────────────
WHATSAPP_PROVIDER=meta
META_PHONE_NUMBER_ID=your_phone_number_id
META_WHATSAPP_BUSINESS_ID=your_business_account_id
META_ACCESS_TOKEN=your_meta_access_token
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
META_API_VERSION=v19.0

# Gupshup (Fallback)
# WHATSAPP_PROVIDER=gupshup
# GUPSHUP_API_KEY=
# GUPSHUP_APP_NAME=

# Twilio (Fallback)
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=

# ─── EMAIL (SendGrid) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@yourcrm.com
EMAIL_FROM_NAME="Real Estate CRM"

# ─── RATE LIMITING ───────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── FILE UPLOAD ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,webp,xlsx,csv

# ─── SWAGGER ─────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# ─── MONITORING ──────────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─── NEXT.JS (Web App) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME="AI Real Estate CRM"
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production
